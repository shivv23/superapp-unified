# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=superapp
DB_PASSWORD=change_me_in_production
DB_NAME=superapp_auth

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# Auth
JWT_SECRET=change_me_to_a_secure_random_string
JWT_EXPIRY=24h

# Services
AUTH_SERVICE_URL=http://localhost:8001
PORTFOLIO_SERVICE_URL=http://localhost:8002
MARKETPLACE_SERVICE_URL=http://localhost:8003
ADVISORY_SERVICE_URL=http://localhost:8004

# Advisory
OPENAI_API_KEY=your-openai-api-key

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_PORTFOLIO_URL=http://localhost:8002
NEXT_PUBLIC_MARKETPLACE_URL=http://localhost:8003
NEXT_PUBLIC_ADVISORY_URL=http://localhost:8004

# Docker
POSTGRES_USER=superapp
POSTGRES_PASSWORD=superapp_secret
POSTGRES_DB=superapp_auth
